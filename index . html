        .notification-toast { position: fixed; bottom: 20px; right: 20px; background: #121212; color: white; padding: 15px 25px; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 200; display: none; animation: slideLeft 0.5s ease-out; }
