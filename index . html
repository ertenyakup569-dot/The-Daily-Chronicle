                    <input type="text" id="pubSource" placeholder="Yazar" class="border p-2 outline-none">
                </div>
                <input type="text" id="pubTitle" placeholder="Başlık" required class="w-full border p-3 font-bold outline-none">
                <textarea id="pubSummary" placeholder="İçerik..." required rows="8" class="w-full border p-3 outline-none"></textarea>
                <button class="w-full bg-blue-600 text-white py-3 font-bold uppercase tracking-widest" data-i18n="publish">Yayına Ver</button>
            </form>
        </div>
    </div>

