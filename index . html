        };

        let user = null;
        // Haberleri dilli yapıya çevirdik
        let news = [
            { 
                id: 1, 
                category: "GÜNDEM", 
                titles: {
                    tr: "Ekonomi Paketi Meclis'e Geliyor",
                    en: "Economy Package Heading to Parliament",
                    es: "Paquete Económico al Parlamento",
                    de: "Wirtschaftspaket kommt ins Parlament"
                }, 
                contents: {
