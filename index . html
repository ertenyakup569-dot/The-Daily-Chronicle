        <div class="bg-white p-8 max-w-2xl w-full shadow-2xl relative border-t-4 border-blue-600">
            <button onclick="closeModal('publishModal')" class="absolute top-4 right-4 text-2xl">&times;</button>
            <h2 class="font-serif text-3xl font-bold mb-4 text-blue-600" data-i18n="publish">Haber Yayınla</h2>
            <form onsubmit="handlePublish(event)" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <select id="pubCategory" class="border p-2 outline-none">
                        <option value="GÜNDEM">GÜNDEM</option>
                        <option value="EKONOMİ">EKONOMİ</option>
                        <option value="TEKNOLOJİ">TEKNOLOJİ</option>
                        <option value="DÜNYA">DÜNYA</option>
