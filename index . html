    <!-- MODALS -->
    <div id="loginModal" class="modal flex items-center justify-center p-4">
        <div class="bg-white p-8 max-w-md w-full shadow-2xl relative border-t-4 border-nytBlack">
            <button onclick="closeModal('loginModal')" class="absolute top-4 right-4 text-2xl">&times;</button>
            <h2 class="font-serif text-3xl font-bold mb-6 text-center" data-i18n="login">Giriş Yap</h2>
            <form onsubmit="handleAuth(event, 'login')" class="space-y-4">
                <input type="email" id="loginEmail" required class="w-full border p-3 outline-none" placeholder="E-posta">
                <input type="password" required class="w-full border p-3 outline-none" placeholder="Şifre">
                <button class="w-full bg-nytBlack text-white py-3 font-bold uppercase tracking-widest" data-i18n="login">Giriş</button>
            </form>
        </div>
    </div>

    <div id="registerModal" class="modal flex items-center justify-center p-4">
        <div class="bg-white p-8 max-w-md w-full shadow-2xl relative border-t-4 border-nytBlack">
            <button onclick="closeModal('registerModal')" class="absolute top-4 right-4 text-2xl">&times;</button>
            <h2 class="font-serif text-3xl font-bold mb-6 text-center" data-i18n="register">Kayıt Ol</h2>
            <form onsubmit="handleAuth(event, 'register')" class="space-y-4">
                <input type="text" required class="w-full border p-3 outline-none" placeholder="Ad Soyad">
                <input type="email" id="regEmail" required class="w-full border p-3 outline-none" placeholder="E-posta">
                <input type="password" required class="w-full border p-3 outline-none" placeholder="Şifre">
                <button class="w-full bg-nytBlack text-white py-3 font-bold uppercase tracking-widest" data-i18n="register">Kayıt Ol</button>
            </form>
        </div>
    </div>

