            },
            { 
                id: 2, 
                category: "TEKNOLOJİ", 
                titles: {
                    tr: "Yapay Zeka Mimariyi Değiştiriyor",
                    en: "AI is Changing Architecture",
                    ja: "AIが建築を変える"
                }, 
                contents: {
                    tr: "AI tarafından tasarlanan ilk gökdelen Dubai'de inşa edilmeye başlandı. Enerji verimliliği %40 daha fazla.",
                    en: "The first AI-designed skyscraper has started construction in Dubai. Energy efficiency is 40% higher.",
                    ja: "AIによって設計された最初の超高層ビルがドバイで建設を開始しました。エネルギー効率は40％向上します。"
                }, 
                source: "TechInsider", 
                image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800", 
                likes: 89, 
                dislikes: 5 
            },
            { 
                id: 3, 
                category: "DÜNYA", 
                titles: {
                    tr: "Okyanus Akıntılarında Kritik Yavaşlama",
                    en: "Critical Slowdown in Ocean Currents",
                    fr: "Ralentissement critique des courants océaniques"
                }, 
                contents: {
                    tr: "Bilim insanları Atlantik akıntılarının son 1000 yılın en zayıf noktasında olduğunu duyurdu.",
                    en: "Scientists announce Atlantic currents are at their weakest point in the last 1,000 years.",
                    fr: "Les scientifiques annoncent que les courants atlantiques sont à leur point le plus faible depuis 1000 ans."
                }, 
                source: "GreenNature", 
                image: "https://images.unsplash.com/photo-1439405326854-014607f694d7?q=80&w=800", 
                likes: 210, 
                dislikes: 3 
            }
        ];

        const ADMIN_EMAIL = 'ertenyakup569@gmail.com';

        function toggleLang() {
            const menu = document.getElementById('langMenu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        function changeLanguage(lang) {
            currentLang = lang;
            document.getElementById('activeLangLabel').innerText = lang.toUpperCase();
            document.getElementById('langMenu').style.display = 'none';
            updateUI();
        }

        function updateUI() {
            const elements = document.querySelectorAll('[data-i18n]');
            elements.forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[currentLang] && translations[currentLang][key]) {
                    el.innerText = translations[currentLang][key];
                } else if (translations['en'][key]) {
                    el.innerText = translations['en'][key];
                }
            });
            if (user) initSite();
        }

        function handleAuth(e, type) {
            e.preventDefault();
            const email = type === 'login' ? document.getElementById('loginEmail').value : document.getElementById('regEmail').value;
            user = { email: email, package: null };
            closeModal('loginModal'); closeModal('registerModal');
            document.getElementById('landingPage').classList.add('hidden');
            
            if(email === ADMIN_EMAIL) {
                user.package = 'Yönetici';
                document.getElementById('mainSite').classList.remove('hidden');
                initSite();
            } else {
                document.getElementById('packagePage').classList.remove('hidden');
            }
        }

        function selectPackage(pkg) {
            user.package = pkg;
            document.getElementById('packagePage').classList.add('hidden');
            document.getElementById('mainSite').classList.remove('hidden');
            initSite();
        }

        function openPayment(pkg) {
            alert(pkg + " paketi seçildi. Ödeme ekranına yönlendiriliyorsunuz...");
            selectPackage(pkg);
        }

        function initSite() {
            const isAdmin = user.email === ADMIN_EMAIL;
            let badge = '';
            
            if (isAdmin) {
                badge = '<span class="admin-badge">YÖNETİCİ</span>';
                document.getElementById('subStatus').innerText = translations[currentLang]?.admin_mode || translations['en'].admin_mode;
            } else if (user.package === 'Pro') {
                badge = '<span class="pro-badge">YAZAR</span>';
                document.getElementById('subStatus').innerText = translations[currentLang]?.pro_mode || translations['en'].pro_mode;
            } else {
                document.getElementById('subStatus').innerText = `${user.package.toUpperCase()} ${currentLang === 'tr' ? 'ÜYELİK AKTİF' : 'MEMBERSHIP ACTIVE'}`;
            }

            document.getElementById('userBadge').innerHTML = `${user.email} ${badge}`;

            if (user.package === 'Pro' || isAdmin) {
                document.getElementById('pubBtn').classList.remove('hidden');
            }

            const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const localeMap = { tr: 'tr-TR', en: 'en-US', es: 'es-ES', fr: 'fr-FR', de: 'de-DE', zh: 'zh-CN', hi: 'hi-IN', ar: 'ar-SA', pt: 'pt-BR', ru: 'ru-RU', ja: 'ja-JP' };
            const locale = localeMap[currentLang] || 'en-US';
            document.getElementById('current-date').innerText = new Date().toLocaleDateString(locale, dateOptions).toUpperCase();
            
            renderNews();
        }

        function handlePublish(e) {
            e.preventDefault();
            const titleInput = document.getElementById('pubTitle').value;
            const contentInput = document.getElementById('pubSummary').value;
            
            // Yeni haber yayınlandığında o dilde metni kaydediyoruz
            const newNews = {
                id: Date.now(),
                category: document.getElementById('pubCategory').value,
                titles: {},
                contents: {},
                source: document.getElementById('pubSource').value || user.email,
                image: "https://images.unsplash.com/photo-1504711432866-b39424be092f?q=80&w=800",
                likes: 0, dislikes: 0
            };

            newNews.titles[currentLang] = titleInput;
            newNews.contents[currentLang] = contentInput;

            news.unshift(newNews);
            renderNews();
            closeModal('publishModal');
            showNotification(titleInput);
            e.target.reset();
        }

        function showNotification(title) {
            const toast = document.getElementById('emailNotification');
            document.getElementById('notifMessage').innerText = `"${title}" yayına alındı!`;
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 5000);
        }

        function handleReaction(id, type) {
            const isAdmin = user.email === ADMIN_EMAIL;
            if(user.package === 'Ücretsiz' && !isAdmin) {
                alert(currentLang === 'tr' ? "Lütfen üye olun!" : "Please subscribe!");
                return;
            }
            const item = news.find(n => n.id === id);
            if(type === 'like') item.likes++; else item.dislikes++;
            renderNews(window.currentFilter || 'TÜMÜ');
        }

        function deportNews(id) {
            if(confirm("Silmek istediğinize emin misiniz?")) {
                news = news.filter(n => n.id !== id);
                renderNews();
            }
        }

        function getNewsText(obj, lang) {
            if(obj[lang]) return obj[lang];
            if(obj['en']) return obj['en']; // İngilizce fallback
            if(obj['tr']) return obj['tr']; // Türkçe fallback
            return translations[currentLang]?.no_translation || translations['en'].no_translation;
        }

        function renderNews(filter = 'TÜMÜ') {
            window.currentFilter = filter;
            const mainContainer = document.getElementById('main-news');
            const liveFeed = document.getElementById('live-feed');
            const isAdmin = user.email === ADMIN_EMAIL;

            const filtered = filter === 'TÜMÜ' ? news : news.filter(n => n.category === filter);

            mainContainer.innerHTML = filtered.map((n, index) => {
                const title = getNewsText(n.titles, currentLang);
                const content = getNewsText(n.contents, currentLang);

                return `
                <div class="mb-16 border-b border-nytGray pb-12 fade-in">
                    <img src="${n.image}" alt="${title}" class="news-image">
                    <span class="text-nytRed font-bold text-[10px] tracking-[0.2em] uppercase">${translations[currentLang]?.[`cat_${n.category.toLowerCase()}`] || n.category}</span>
                    <h2 class="font-serif ${index === 0 ? 'text-5xl' : 'text-3xl'} font-bold mt-4 mb-5 leading-tight hover:text-gray-700 cursor-pointer">${title}</h2>
                    <p class="text-gray-700 leading-relaxed font-serif text-xl mb-6">${content}</p>
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-6">
                            <button onclick="handleReaction(${n.id}, 'like')" class="flex items-center gap-2 group">
                                <span class="text-xl group-hover:scale-125 transition-transform">👍</span>
                                <span class="text-xs font-bold">${n.likes}</span>
                            </button>
                            <button onclick="handleReaction(${n.id}, 'dislike')" class="flex items-center gap-2 group">
                                <span class="text-xl group-hover:scale-125 transition-transform">👎</span>
                                <span class="text-xs font-bold">${n.dislikes}</span>
                            </button>
                        </div>
                        <div class="text-right">
                            <span class="text-[11px] font-bold italic">${n.source}</span>
                            ${isAdmin ? `<div><button onclick="deportNews(${n.id})" class="admin-deport">SİL (DEPORT)</button></div>` : ''}
                        </div>
                    </div>
                </div>
            `;}).join('');

            liveFeed.innerHTML = news.slice(0, 8).map(n => `
                <li class="border-l-4 border-nytBlack pl-5 py-1 hover:bg-gray-50 cursor-pointer transition-colors" onclick="alert('${getNewsText(n.titles, currentLang)}')">
                    <p class="text-[9px] font-black text-nytRed uppercase tracking-widest">${translations[currentLang]?.[`cat_${n.category.toLowerCase()}`] || n.category}</p>
                    <p class="font-serif font-bold text-base leading-snug">${getNewsText(n.titles, currentLang)}</p>
                </li>
            `).join('');
        }

        function filterCategory(cat) {
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active-nav'));
            if(event && event.target.classList.contains('nav-btn')) event.target.classList.add('active-nav');
            renderNews(cat);
        }

        function openModal(id) { document.getElementById(id).style.display = "flex"; }
        function closeModal(id) { document.getElementById(id).style.display = "none"; }
    </script>
</body>
</html>
