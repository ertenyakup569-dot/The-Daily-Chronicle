<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE DAILY CHRONICLE | Canlı Haber Akışı</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #fcfcfc; color: #121212; }
        .serif { font-family: 'Playfair Display', serif; }
        .article-card:hover h2 { color: #8B0000; }
        .loading-shimmer {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }
        @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
        .live-dot { width: 8px; height: 8px; background-color: #8B0000; border-radius: 50%; display: inline-block; margin-right: 8px; animation: pulse 1s infinite; }
        @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.5); opacity: 0.5; } 100% { transform: scale(1); opacity: 1; } }
        .nav-link.active { color: #8B0000; border-bottom: 2px solid #8B0000; }
        .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
        
        #alert-box { display: none; }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="alert-box" class="fixed top-4 right-4 bg-black text-white p-4 text-[10px] font-bold z-50 shadow-2xl serif italic border-l-4 border-red-600">
        MOD: ÇEVRİMDIŞI ARŞİV VERİLERİ GÖSTERİLİYOR.
    </div>

    <header class="max-w-7xl mx-auto text-center border-b border-black pb-4">
        <div class="text-xs uppercase tracking-widest mb-2 font-semibold" id="current-date">YÜKLENİYOR...</div>
        <h1 class="serif text-5xl md:text-7xl font-black tracking-tighter mb-4">THE DAILY CHRONICLE</h1>
        <nav id="main-nav" class="flex flex-wrap justify-center gap-6 border-t border-gray-300 pt-4 text-xs font-bold uppercase tracking-wider">
            <a href="#" data-category="general" class="nav-link active hover:text-red-800 transition">Gündem</a>
            <a href="#" data-category="business" class="nav-link hover:text-red-800 transition">Ekonomi</a>
            <a href="#" data-category="technology" class="nav-link hover:text-red-800 transition">Teknoloji</a>
            <a href="#" data-category="science" class="nav-link hover:text-red-800 transition">Bilim</a>
            <a href="#" data-category="health" class="nav-link hover:text-red-800 transition">Sağlık</a>
            <a href="#" data-category="entertainment" class="nav-link hover:text-red-800 transition">Magazin</a>
            <a href="#" data-category="sports" class="nav-link hover:text-red-800 transition">Spor</a>
        </nav>
    </header>

    <main class="max-w-7xl mx-auto mt-8 grid grid-cols-1 lg:grid-cols-4 gap-8">
        <section class="lg:col-span-3">
            <div class="flex items-center justify-between border-b-2 border-black mb-6 pb-2">
                <h2 id="category-title" class="serif text-2xl font-bold italic uppercase">Gündem</h2>
                <button onclick="refreshCurrentCategory()" class="text-xs bg-black text-white px-3 py-1 hover:bg-red-900 transition uppercase tracking-tighter">Yenile</button>
            </div>

            <div id="news-container" class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="space-y-4"><div class="h-64 loading-shimmer w-full"></div><div class="h-8 loading-shimmer w-3/4"></div></div>
                <div class="space-y-4"><div class="h-64 loading-shimmer w-full"></div><div class="h-8 loading-shimmer w-3/4"></div></div>
            </div>
        </section>

        <aside class="lg:col-span-1 border-l border-gray-200 pl-0 lg:pl-8">
            <div class="border-b-2 border-black mb-6 pb-2">
                <h2 class="serif text-xl font-bold"><span class="live-dot"></span>ANLIK AKIŞ</h2>
            </div>
            <div id="live-ticker" class="space-y-6">
                <p class="text-sm text-gray-500 italic">Veriler taranıyor...</p>
            </div>
        </aside>
    </main>

    <footer class="max-w-7xl mx-auto mt-20 pt-8 border-t border-gray-300 text-center text-xs text-gray-500 pb-10">
        <p>© 2026 The Daily Chronicle. Tüm hakları saklıdır. Haberler NewsAPI (veya yedek sunucu) üzerinden taranmaktadır.</p>
    </footer>

    <script>
        const API_KEY = '5f4c6e9e4f5d4a1b9c8d7e6f5a4b3c2d'; 
        const newsContainer = document.getElementById('news-container');
        const liveTicker = document.getElementById('live-ticker');
        const dateElement = document.getElementById('current-date');
        const categoryTitle = document.getElementById('category-title');
        const navLinks = document.querySelectorAll('.nav-link');
        const alertBox = document.getElementById('alert-box');

        let currentCategory = 'general';

        dateElement.innerText = new Date().toLocaleDateString('tr-TR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase();

        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                navLinks.forEach(l => l.classList.remove('active'));
                link.classList.add('active');
                currentCategory = link.getAttribute('data-category');
                categoryTitle.innerText = link.innerText;
                fetchNews(currentCategory);
            });
        });

        async function fetchNews(category = 'general') {
            newsContainer.innerHTML = `
                <div class="space-y-4"><div class="h-64 loading-shimmer w-full"></div><div class="h-8 loading-shimmer w-3/4"></div></div>
                <div class="space-y-4"><div class="h-64 loading-shimmer w-full"></div><div class="h-8 loading-shimmer w-3/4"></div></div>
            `;
            
            // NewsAPI Ücretsiz Planı bulut ortamlarında (Canvas gibi) 426 hatası verebilir.
            const url = `https://newsapi.org/v2/top-headlines?country=us&category=${category}&apiKey=${API_KEY}`;
            
            try {
                const response = await fetch(url);
                
                // 426 Upgrade Required veya diğer hataları kontrol et
                if (!response.ok) {
                    throw new Error(`HTTP Hata: ${response.status}`);
                }
                
                const data = await response.json();
                
                if (data.status === 'ok' && data.articles && data.articles.length > 0) {
                    alertBox.style.display = 'none';
                    renderNews(data.articles);
                } else {
                    throw new Error('API verisi eksik.');
                }
            } catch (error) {
                console.warn("Bağlantı/Protokol Hatası (426):", error.message);
                // 426 Hatası durumunda "Demo/Yedek" modunu aktif et
                alertBox.style.display = 'block';
                renderMockNews(category);
            }
        }

        function renderNews(articles) {
            newsContainer.innerHTML = '';
            liveTicker.innerHTML = '';

            articles.forEach((article, index) => {
                const imageUrl = article.urlToImage || `https://images.unsplash.com/photo-1585829365234-781fcd50c819?auto=format&fit=crop&w=800&q=60`;

                if (index < 8) {
                    newsContainer.innerHTML += `
                        <article class="article-card group cursor-pointer border-b border-gray-200 pb-8 last:border-0" onclick="window.open('${article.url}', '_blank')">
                            <div class="overflow-hidden bg-gray-100 mb-4">
                                <img src="${imageUrl}" 
                                     onerror="this.src='https://via.placeholder.com/800x500/f3f4f6/374151?text=Haber+Gorseli'"
                                     class="w-full h-56 object-cover grayscale hover:grayscale-0 transition duration-700 transform group-hover:scale-105">
                            </div>
                            <span class="text-[10px] font-bold text-red-900 uppercase tracking-widest">${article.source.name || 'Chronicle News'}</span>
                            <h2 class="serif text-2xl font-bold leading-tight my-2 group-hover:underline">${article.title}</h2>
                            <p class="text-sm text-gray-700 leading-relaxed line-clamp-3">${article.description || 'Haberin tam metni ve uzman görüşleri için lütfen orijinal kaynağı ziyaret edin.'}</p>
                            <div class="mt-4 pt-2 border-t border-dotted border-gray-400 flex justify-between items-center text-[11px] text-gray-500 italic">
                                <span>Kaynak: ${article.source.name || 'Arşiv'}</span>
                                <span class="text-blue-800 font-bold not-italic">DETAYLAR →</span>
                            </div>
                        </article>
                    `;
                }

                liveTicker.innerHTML += `
                    <div class="border-b border-gray-100 pb-4 group cursor-pointer" onclick="window.open('${article.url}', '_blank')">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-[10px] text-red-700 font-bold">${new Date(article.publishedAt).toLocaleTimeString('tr-TR', {hour: '2-digit', minute:'2-digit'})}</span>
                            <span class="text-[9px] uppercase text-gray-400 font-bold">${article.source.name || 'FLAŞ'}</span>
                        </div>
                        <h4 class="text-sm font-semibold leading-snug group-hover:text-red-800">${article.title}</h4>
                    </div>
                `;
            });
        }

        function renderMockNews(category) {
            // Her kategoriye özel içerik üreten yedek veri seti
            const categoryData = {
                general: [
                    { title: "Küresel Siyasette Yeni İttifaklar Dönemi", desc: "Diplomatik kaynaklar, önümüzdeki ay yapılacak zirvede tarihi kararların alınacağını öngörüyor.", img: "https://images.unsplash.com/photo-1529107386315-e1a2ed48a620?w=800" },
                    { title: "Büyük Şehirlerde Altyapı Reformu", desc: "Akıllı şehir projeleri kapsamında ulaştırma ve enerji hatları tamamen modernize ediliyor.", img: "https://images.unsplash.com/photo-1449824913935-59a10b8d2000?w=800" }
                ],
                business: [
                    { title: "Merkez Bankası Faiz Kararını Açıkladı", desc: "Piyasaların beklediği faiz kararı açıklandı. Dolar ve altın piyasasında hareketlilik gözleniyor.", img: "https://images.unsplash.com/photo-1611974717482-98252c003005?w=800" },
                    { title: "Startup Yatırımlarında Rekor Artış", desc: "Bu yılın ilk çeyreğinde teknoloji girişimlerine yapılan yatırımlar geçen yıla oranla %40 arttı.", img: "https://images.unsplash.com/photo-1553729459-efe14ef6055d?w=800" }
                ],
                technology: [
                    { title: "Yapay Zeka Mimarisinde Devrim", desc: "Yeni nesil işlemciler sayesinde yapay zeka modelleri artık %80 daha az enerji harcayacak.", img: "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=800" },
                    { title: "Kuantum Bilgisayarlar Ticari Kullanıma Hazır", desc: "Büyük bir teknoloji firması, ilk ticari kuantum bilgisayar modülünü duyurdu.", img: "https://images.unsplash.com/photo-1518770660439-4636190af475?w=800" }
                ]
            };

            const selectedData = categoryData[category] || categoryData.general;
            
            const mockArticles = selectedData.map(item => ({
                title: item.title,
                description: item.desc,
                source: { name: "Chronicle Archive" },
                url: "#",
                urlToImage: item.img,
                publishedAt: new Date().toISOString()
            }));

            // Listeyi doldurmak için ek sahte veriler ekle
            for(let i=0; i<4; i++) {
                mockArticles.push({
                    title: `${category.toUpperCase()} Analizi: Gelecek Beklentileri #${i+1}`,
                    description: "Kapsamlı dosya haberimizde uzman görüşlerine ve istatistiklere yer verdik.",
                    source: { name: "Analysis" },
                    url: "#",
                    urlToImage: `https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=800&q=60`,
                    publishedAt: new Date().toISOString()
                });
            }
            
            renderNews(mockArticles);
        }

        function refreshCurrentCategory() { fetchNews(currentCategory); }
        window.onload = () => fetchNews(currentCategory);
        setInterval(refreshCurrentCategory, 300000);
    </script>
</body>
</html>
