            ar: { register: "تسجيل", login: "دخول", free: "مجاني", buy_now: "اشتري الآن", publish: "نشر", cat_world: "عالم", no_translation: "الترجمة غير متوفرة." },
            pt: { register: "Registrar", login: "Entrar", free: "Grátis", buy_now: "Comprar", publish: "PUBLICAR", cat_world: "Mundo", no_translation: "Tradução não disponível." },
            ru: { register: "Регистрация", login: "Вход", free: "Бесплатно", buy_now: "Купить", publish: "ОПУБЛИКОВАТЬ", cat_world: "Мир", no_translation: "Перевод отсутствует." },
